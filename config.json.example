{
  "name": "dashboard-financeiro",
  "version": "1.0.0",
  "description": "Dashboard para acompanhamento de contratos cancelados com comodato ativo e suspensos com boletos vencidos",
  "repository": "git@github.com:ahlrodrigues/dashboard_financeiro.git",
  "url_base": "https://sgp.net4you.com.br",
  "basic_auth": {
    "username": "robo",
    "password": "CHANGE_ME"
  },
  "app_token_auth": {
    "app": "financeiro",
    "token": "CHANGE_ME"
  },
  "auth": {
    "enabled": true,
    "admin_group": "financeiro",
    "jwt_secret": "CHANGE_ME",
    "token_ttl_seconds": 43200
  },
  "dashboard": {
    "suspended_status_codes": [],
    "suspended_status_tokens": [
      "SUSP"
    ]
  },
  "requerer": {
    "conteudo": "Financeiro - Negociação (Suspenso)",
    "ocorrenciatipo": 4018,
    "motivoos": "",
    "setor": 1,
    "os_prioridade": 2,
    "status_field": "status",
    "status_value": "Encerrada",
    "encerrar_os_field": "encerrar_os",
    "encerrar_os_value": "1",
    "classificacao_field": "classificacao",
    "classificacao_value": "Suspenso",
    "lookup_endpoints": [
      "/ura/ocorrencia/list/",
      "/ura/chamado/list/",
      "/ura/ordemservico/list/"
    ]
  }
}
